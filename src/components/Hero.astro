---
---
<section id="hero" class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-brand-dark px-4 sm:px-6 lg:px-8 py-20">
  
  <!-- CLI Studios-style dark overlay & background media -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?auto=format&fit=crop&w=1920&q=80" 
      alt="Star Dance Academy Raipur" 
      class="w-full h-full object-cover opacity-35 object-center scale-105 animate-pulse-subtle"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/80 to-transparent"></div>
    <div class="absolute inset-0 bg-radial-gradient from-transparent to-brand-dark/95"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto w-full text-center sm:text-left flex flex-col justify-center h-full">
    
    <!-- Local/Social Badge -->
    <div class="inline-flex items-center gap-2 bg-brand-red/10 border border-brand-red/30 px-4 py-2 rounded-full text-brand-red font-accent font-black tracking-widest text-xs uppercase w-fit mx-auto sm:mx-0 mb-6 animate-fade-in">
      <span class="inline-block w-2 h-2 rounded-full bg-brand-red animate-ping"></span>
      Raipur's #1 Dance Studio
    </div>

    <!-- Broadway Dance Center Bold Headings (Stark, structured typography) -->
    <h1 class="font-display font-black text-3xl sm:text-5xl md:text-6xl lg:text-7xl uppercase leading-tight tracking-tighter text-brand-light max-w-5xl mb-6">
      Transforming <br class="hidden sm:inline" />
      <span class="text-gradient-red-gold">passion</span> into <br />
      <span class="text-stroke text-stroke-hover cursor-default">performance</span>
    </h1>

    <p class="font-sans text-brand-gray-light text-base sm:text-lg md:text-xl max-w-xl font-light leading-relaxed mb-10">
      Raipur's premier training for all ages & styles. Unleash your potential.
    </p>

    <!-- CTAs and Social Proof highlights -->
    <div class="flex flex-col sm:flex-row items-center gap-6">
      
      <!-- Primary CTA button (skewed, bold) -->
      <a 
        href="#contact" 
        id="hero-primary-cta"
        class="w-full sm:w-auto px-8 py-4 bg-brand-red hover:bg-brand-red-dark text-brand-light text-sm font-accent font-black tracking-widest uppercase skew-btn transition-all duration-200 hover:shadow-lg hover:shadow-brand-red/30 border-2 border-brand-red text-center"
      >
        <span>Book A Free Trial Class</span>
      </a>

      <!-- Secondary CTA button -->
      <a 
        href="#classes" 
        class="w-full sm:w-auto px-8 py-4 bg-transparent hover:bg-white/5 text-brand-light text-sm font-accent font-black tracking-widest uppercase skew-btn transition-all duration-200 border-2 border-brand-gray-dark text-center"
      >
        <span>Explore Styles</span>
      </a>

      <!-- Google Rating Metric in Hero (for trust building) -->
      <div class="flex flex-col items-center sm:items-start ml-0 sm:ml-4">
        <div class="flex items-center gap-1">
          <span class="text-brand-gold text-lg">★★★★★</span>
          <span class="font-accent font-bold text-brand-light">4.9/5</span>
        </div>
        <span class="text-xs text-brand-gray font-sans font-medium">182+ Google Reviews</span>
      </div>

    </div>

  </div>

  <!-- BDC Grid Element Decoration (subtle graphic borders) -->
  <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-brand-gray-dark to-transparent"></div>
  <div class="absolute top-0 right-10 w-px h-full bg-brand-gray-dark/20 hidden lg:block"></div>
  <div class="absolute top-0 left-20 w-px h-full bg-brand-gray-dark/20 hidden lg:block"></div>

</section>
