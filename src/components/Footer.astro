---

---

<footer
  id="contact"
  class="relative bg-brand-dark px-4 sm:px-6 lg:px-8 pt-24 pb-12 border-t border-white/5 overflow-hidden"
>
  <div class="max-w-7xl mx-auto">
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 pb-16 border-b border-brand-gray-dark"
    >
      <!-- Column 1: Contact Details & Info (BDC Bold Typography) -->
      <div class="flex flex-col justify-between">
        <div>
          <div class="flex items-center gap-2 mb-6 group">
            <div
              class="w-10 h-10 flex items-center justify-center bg-brand-red skew-btn text-brand-dark font-display font-black text-xl leading-none"
            >
              <span>S</span>
            </div>
            <div
              class="flex flex-col font-display font-black tracking-tight leading-none uppercase"
            >
              <span class="text-lg text-brand-light">Star Dance</span>
              <span class="text-[10px] tracking-[0.2em] text-brand-gold"
                >Academy</span
              >
            </div>
          </div>

          <h3
            class="font-display font-black text-2xl sm:text-3xl uppercase tracking-tight text-brand-light mb-8"
          >
            READY TO <span class="text-gradient-red-gold">START DANCING?</span>
          </h3>

          <!-- Details List -->
          <div
            class="space-y-6 font-sans text-brand-gray-light text-sm sm:text-base"
          >
            <!-- Address -->
            <div>
              <p class="font-bold text-brand-light">Studio Location:</p>
              <p class="mt-1">
                418, Samta Colony Main Rd, Samta Colony, Raipur, Chhattisgarh
                492001
              </p>
            </div>

            <!-- Phone -->
            <div>
              <p class="font-bold text-brand-light">Call / WhatsApp:</p>
              <a
                href="tel:+919329559903"
                class="mt-1 block text-brand-red hover:underline font-accent font-black tracking-wide text-base sm:text-lg"
                >+91 93295 59903</a
              >
            </div>

            <!-- Hours -->
            <div>
              <p class="font-bold text-brand-light">Operating Hours:</p>
              <p class="mt-1">Monday – Saturday: 4:00 PM – 9:00 PM</p>
              <p class="text-xs text-brand-gray mt-0.5">Sundays: Closed</p>
            </div>

            <!-- Socials -->
            <div>
              <p class="font-bold text-brand-light">Instagram Handle:</p>
              <a
                href="https://www.instagram.com/stardanceacademyindia/"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1 inline-flex items-center gap-1.5 text-brand-gold hover:text-brand-light transition-colors font-accent font-semibold text-sm"
              >
                @stardanceacademyindia
                <svg
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  ></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Column 2: Inquiry Form -->
      <div class="flex flex-col justify-center">
        <!-- Quick Form Validation Container (Sleek Dark Look) -->
        <div class="glass-card p-6 border border-white/5">
          <h4
            class="font-display font-black text-lg uppercase tracking-tight text-brand-light mb-4"
          >
            Chat & Inquiry on WhatsApp
          </h4>
          <form id="contact-form" class="space-y-4" action="#">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input
                type="text"
                id="form-name"
                placeholder="Your Name"
                class="w-full bg-brand-dark-card border border-brand-gray-dark px-4 py-3 text-base text-brand-light focus:border-brand-red outline-none transition-colors rounded-none font-sans"
              />
            </div>
            <select
              id="form-style"
              class="w-full bg-brand-dark-card border border-brand-gray-dark px-4 py-3 text-base text-brand-light focus:border-brand-red outline-none transition-colors rounded-none font-sans appearance-none cursor-pointer"
            >
              <option value="" disabled selected
                >Select Your Preferred Style (Optional)</option
              >
              <option value="hiphop">Hip Hop & Urban</option>
              <option value="contemporary">Contemporary & Lyrical</option>
              <option value="bollywood">Bollywood & Commercial</option>
              <option value="kathak">Indian Classical (Kathak)</option>
              <option value="jazz">Jazz & Street Jazz</option>
              <option value="zumba">Zumba & Dance Fit</option>
            </select>
            <button
              type="submit"
              class="w-full py-3.5 bg-brand-red hover:bg-brand-red-dark text-brand-light text-xs font-accent font-black tracking-widest uppercase skew-btn transition-all duration-200 flex items-center justify-center gap-2 cursor-pointer"
            >
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.455 5.703 1.456h.004c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path>
              </svg>
              <span>Chat on WhatsApp</span>
            </button>
          </form>

          <!-- Success Status -->
          <div
            id="form-status"
            class="hidden mt-3 text-center text-xs font-accent font-bold text-brand-gold animate-fade-in"
          >
            Opening WhatsApp Chat...
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Copyright -->
    <div
      class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs font-accent font-bold text-brand-gray"
    >
      <p>
        &copy; {new Date().getFullYear()} Star Dance Academy. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#about" class="hover:text-brand-light transition-colors"
          >About</a
        >
        <a href="#classes" class="hover:text-brand-light transition-colors"
          >Classes</a
        >
        <a
          href="#contact"
          class="hover:text-brand-light transition-colors font-semibold text-brand-red"
          >Book Batch</a
        >
      </div>
    </div>
  </div>

  <script>
    // Quick Form Interceptor to compile fields and redirect to the academy's phone number on WhatsApp
    const form = document.getElementById(
      "contact-form",
    ) as HTMLFormElement | null;
    const status = document.getElementById("form-status");

    if (form) {
      form.addEventListener("submit", (e) => {
        e.preventDefault();

        const nameInput = document.getElementById(
          "form-name",
        ) as HTMLInputElement | null;
        const phoneInput = document.getElementById(
          "form-phone",
        ) as HTMLInputElement | null;
        const styleSelect = document.getElementById(
          "form-style",
        ) as HTMLSelectElement | null;

        const name = nameInput ? nameInput.value.trim() : "";
        const phone = phoneInput ? phoneInput.value.trim() : "";
        const style =
          styleSelect && styleSelect.selectedIndex > 0
            ? styleSelect.options[styleSelect.selectedIndex].text
            : "";

        // Display success state
        if (status) {
          status.classList.remove("hidden");
        }

        // Compile WhatsApp Message
        let baseText = "";
        if (name || phone || style) {
          baseText = `Hi Star Dance Academy! I would like to inquire about booking a trial class.\n\nName: ${name || "Not provided"}\nPhone: ${phone || "Not provided"}\nStyle: ${style || "Not provided"}\n\nLet me know batch availability. Thanks!`;
        } else {
          baseText = `Hi Star Dance Academy! I absolutely love your academy and would like to inquire about batch schedules, fee structure, and trial classes. Let's chat!`;
        }

        const encodedText = encodeURIComponent(baseText);
        const whatsappUrl = `https://wa.me/919329559903?text=${encodedText}`;

        setTimeout(() => {
          window.open(whatsappUrl, "_blank");
          if (status) status.classList.add("hidden");
          form.reset();
        }, 1000);
      });
    }
  </script>
</footer>
