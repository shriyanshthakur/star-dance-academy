---

---

<section
  id="about"
  class="relative bg-brand-dark px-4 sm:px-6 lg:px-8 py-24 sm:py-32 overflow-hidden"
>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Left Column: Story & Philosophy (BDC Bold structured typography) -->
      <div class="lg:col-span-7 flex flex-col justify-center">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-1 bg-brand-red"></div>
          <span
            class="font-accent font-bold tracking-widest text-sm uppercase text-brand-red"
            >The Academy Vibe</span
          >
        </div>

        <h2
          class="font-display font-black text-3xl sm:text-4xl lg:text-5xl uppercase tracking-tighter text-brand-light mb-8"
        >
          WHERE passion MEETS <br />
          <span class="text-gradient-red-gold">PROFESSIONAL TRAINING</span>
        </h2>

        <p
          class="font-sans text-brand-gray-light text-base sm:text-lg leading-relaxed mb-6"
        >
          Star Dance Academy is Raipur's premier destination for dancers of all
          levels. From your very first steps to advanced choreographies, our
          mission is to provide an energetic, inclusive, and high-caliber
          environment that allows your passion to thrive.
        </p>

        <p
          class="font-sans text-brand-gray-light text-base leading-relaxed mb-8"
        >
          Inspired by top global conservatories, we bring a world-class training
          curriculum to Raipur. Our studios in Samta Colony feature
          shock-absorbent dance floors, full-length mirrors, professional audio
          setups, and fully air-conditioned spaces to give our students the
          ultimate dance experience.
        </p>

        <!-- Stats Grid (Structured display) -->
        <div
          class="grid grid-cols-2 sm:grid-cols-3 gap-6 pt-6 border-t border-brand-gray-dark"
        >
          <div>
            <span
              class="block font-display font-black text-3xl sm:text-4xl text-brand-red"
              >8+</span
            >
            <span
              class="text-xs uppercase font-accent font-bold tracking-wider text-brand-gray-light"
              >Years of Legacy</span
            >
          </div>
          <div>
            <span
              class="block font-display font-black text-3xl sm:text-4xl text-brand-gold"
              >1,500+</span
            >
            <span
              class="text-xs uppercase font-accent font-bold tracking-wider text-brand-gray-light"
              >Students Trained</span
            >
          </div>
          <div>
            <span
              class="block font-display font-black text-3xl sm:text-4xl text-brand-light"
              >10+</span
            >
            <span
              class="text-xs uppercase font-accent font-bold tracking-wider text-brand-gray-light"
              >Elite Coaches</span
            >
          </div>
        </div>
      </div>

      <!-- Right Column: Visual Frames (BDC / CLI Studios structured grids) -->
      <div class="lg:col-span-5 grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- Frame 1 (Contemporary jump) -->
        <div class="bdc-frame aspect-[3/4] flex flex-col justify-between group">
          <div class="relative overflow-hidden w-full h-[85%]">
            <img
              src="https://images.unsplash.com/photo-1547153760-18fc86324498?auto=format&fit=crop&w=800&q=80"
              alt="Contemporary Dance Raipur"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-transparent to-transparent"
            >
            </div>
          </div>
          <div
            class="p-2 border-t border-brand-gray-dark flex items-center justify-between"
          >
            <span
              class="font-accent font-black text-xs uppercase tracking-widest text-brand-light"
              >Expression</span
            >
            <span class="text-[10px] text-brand-gray font-mono"
              >01 / CONTEMPORARY</span
            >
          </div>
        </div>

        <!-- Frame 2 (Hip-hop/Urban dance style) -->
        <div
          class="bdc-frame aspect-[3/4] flex flex-col justify-between group sm:translate-y-6"
        >
          <div class="relative overflow-hidden w-full h-[85%]">
            <img
              src="https://plus.unsplash.com/premium_photo-1710064057043-d301e344e348?auto=format&fit=crop&w=600&q=80"
              alt="Hip-Hop Dance Raipur"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-transparent to-transparent"
            >
            </div>
          </div>
          <div
            class="p-2 border-t border-brand-gray-dark flex items-center justify-between"
          >
            <span
              class="font-accent font-black text-xs uppercase tracking-widest text-brand-red"
              >Power</span
            >
            <span class="text-[10px] text-brand-gray font-mono"
              >02 / URBAN HIP HOP</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative blur behind images (CLI Studios styling) -->
  <div
    class="absolute right-0 bottom-1/4 w-96 h-96 bg-brand-red/5 rounded-full blur-[120px] -z-10 pointer-events-none"
  >
  </div>
  <div
    class="absolute left-0 top-1/4 w-96 h-96 bg-brand-gold/5 rounded-full blur-[120px] -z-10 pointer-events-none"
  >
  </div>
</section>
