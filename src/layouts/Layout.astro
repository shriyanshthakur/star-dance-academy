---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Star Dance Academy | Best Dance Class in Raipur", 
  description = "Transforming passion into performance. Join Raipur's premier dance academy for all ages and styles. Rated 4.9/5 stars on Google (182 reviews)."
} = Astro.props;

// Local Business JSON-LD Schema
const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Star Dance Academy",
  "image": "https://stardanceacademy.in/assets/images/dance-hero.jpg",
  "@id": "https://stardanceacademy.in/#academy",
  "url": "https://stardanceacademy.in",
  "telephone": "+919329559903",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "418, Samta Colony Main Rd, Samta Colony",
    "addressLocality": "Raipur",
    "addressRegion": "Chhattisgarh",
    "postalCode": "492001",
    "addressCountry": "IN"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 21.2464,
    "longitude": 81.6198
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday"
      ],
      "opens": "16:00",
      "closes": "21:00"
    }
  ],
  "sameAs": [
    "https://www.instagram.com/stardanceacademyindia/"
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "182",
    "bestRating": "5",
    "worstRating": "1"
  }
};
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://stardanceacademy.in" />
    <meta property="og:image" content="https://stardanceacademy.in/assets/images/dance-hero.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Local SEO Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <style>
      /* Ensure fonts load smoothly */
      body {
        font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
        overflow-x: hidden;
      }
    </style>
  </head>
  <body class="bg-brand-dark text-brand-light antialiased selection:bg-brand-red selection:text-white">
    
    <!-- Premium Header / Navigation (Glassmorphic) -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-brand-dark/70 backdrop-blur-md border-b border-white/5 transition-all duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        
        <!-- Brand Logo (BDC Inspired - Bold, High Contrast) -->
        <a href="#" class="flex items-center gap-2 group" id="nav-logo">
          <div class="relative w-10 h-10 flex items-center justify-center bg-brand-red skew-btn text-brand-dark font-display font-black text-xl leading-none">
            <svg class="w-5 h-5 fill-brand-dark" viewBox="0 0 24 24">
              <path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.787 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.132 9.21l8.2-1.192z"/>
            </svg>
          </div>
          <div class="flex flex-col font-display font-black tracking-tight leading-none uppercase">
            <span class="text-lg text-brand-light group-hover:text-brand-red transition-colors duration-200">Star Dance</span>
            <span class="text-[10px] tracking-[0.2em] text-brand-gold">Academy</span>
          </div>
        </a>

        <!-- Desktop Navigation Links -->
        <nav class="hidden md:flex items-center gap-8 font-accent font-semibold text-sm tracking-wider uppercase text-brand-gray-light">
          <a href="#" class="hover:text-brand-light transition-colors relative py-2 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-brand-red after:transition-all hover:after:w-full">Home</a>
          <a href="#about" class="hover:text-brand-light transition-colors relative py-2 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-brand-red after:transition-all hover:after:w-full">Academy</a>
          <a href="#classes" class="hover:text-brand-light transition-colors relative py-2 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-brand-red after:transition-all hover:after:w-full">Styles</a>
          <a href="#testimonials" class="hover:text-brand-light transition-colors relative py-2 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-brand-red after:transition-all hover:after:w-full">Reviews</a>
          <a href="#contact" class="hover:text-brand-light transition-colors relative py-2 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-brand-red after:transition-all hover:after:w-full">Contact</a>
        </nav>

        <!-- CTA & Google Rating Badge (Broadway Dance Center Energetic CTA) -->
        <div class="flex items-center gap-3">
          <div class="hidden lg:flex items-center gap-1.5 bg-brand-dark-card border border-white/10 px-3 py-1.5 rounded-full text-xs font-accent font-bold">
            <span class="text-brand-gold">★</span>
            <span class="text-brand-light">4.9/5</span>
            <span class="text-brand-gray">(182 Reviews)</span>
          </div>
          <a 
            href="#contact" 
            id="header-cta"
            class="px-4 sm:px-5 py-2.5 bg-brand-red hover:bg-brand-red-dark text-brand-light text-xs font-accent font-black tracking-widest uppercase skew-btn transition-all duration-200 hover:shadow-lg hover:shadow-brand-red/25 border border-brand-red"
          >
            <span>Book A Trial</span>
          </a>

          <!-- Mobile Menu Button (Hamburger) -->
          <button 
            id="menu-btn" 
            class="md:hidden p-2 text-brand-light hover:text-brand-red focus:outline-none z-50 relative"
            aria-label="Toggle Menu"
          >
            <svg id="hamburger-icon" class="w-6 h-6 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" />
            </svg>
            <svg id="close-icon" class="w-6 h-6 hidden transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile Menu Drawer (Overlay) -->
    <div 
      id="mobile-menu" 
      class="fixed inset-0 z-40 bg-brand-dark/98 backdrop-blur-xl translate-x-full transition-transform duration-300 md:hidden flex flex-col pt-28 px-8 gap-6 text-xl font-accent font-black tracking-widest uppercase text-brand-gray-light"
    >
      <a href="#" class="mobile-link hover:text-brand-light py-2 border-b border-white/5">Home</a>
      <a href="#about" class="mobile-link hover:text-brand-light py-2 border-b border-white/5">Academy</a>
      <a href="#classes" class="mobile-link hover:text-brand-light py-2 border-b border-white/5">Styles</a>
      <a href="#testimonials" class="mobile-link hover:text-brand-light py-2 border-b border-white/5">Reviews</a>
      <a href="#contact" class="mobile-link hover:text-brand-light py-2 border-b border-white/5">Contact</a>
      <div class="mt-8 flex flex-col gap-4">
        <div class="flex items-center gap-1.5 bg-brand-dark-card border border-white/10 px-4 py-2 w-fit rounded-full text-xs font-accent font-bold">
          <span class="text-brand-gold">★</span>
          <span class="text-brand-light">4.9/5 (182 Reviews)</span>
        </div>
        <a 
          href="#contact" 
          class="mobile-link w-full py-4 bg-brand-red hover:bg-brand-red-dark text-brand-light text-sm font-accent font-black tracking-widest uppercase skew-btn transition-all duration-200 border border-brand-red text-center"
        >
          <span>Book A Trial</span>
        </a>
      </div>
    </div>

    <main class="pt-20">
      <slot />
    </main>

    <script>
      const menuBtn = document.getElementById('menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');
      const closeIcon = document.getElementById('close-icon');
      const mobileLinks = document.querySelectorAll('.mobile-link');

      function toggleMenu() {
        if (!mobileMenu || !hamburgerIcon || !closeIcon) return;
        const isOpen = mobileMenu.classList.contains('translate-x-0');
        if (isOpen) {
          mobileMenu.classList.remove('translate-x-0');
          mobileMenu.classList.add('translate-x-full');
          hamburgerIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          document.body.style.overflow = 'auto';
        } else {
          mobileMenu.classList.remove('translate-x-full');
          mobileMenu.classList.add('translate-x-0');
          hamburgerIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }
      }

      if (menuBtn && mobileMenu && hamburgerIcon && closeIcon) {
        menuBtn.addEventListener('click', toggleMenu);
        
        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.remove('translate-x-0');
            mobileMenu.classList.add('translate-x-full');
            hamburgerIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            document.body.style.overflow = 'auto';
          });
        });
      }
    </script>
  </body>
</html>
